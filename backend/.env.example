FASTAPI_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/tamil_coach
JWT_SECRET=your-strong-random-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=168

GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=/app/service-account-key.json

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models

GOOGLE_STT_API_KEY=your-stt-api-key
GOOGLE_STT_MODEL=latest
GOOGLE_STT_ENDPOINT=speech.googleapis.com

GOOGLE_TTS_API_KEY=your-tts-api-key
GOOGLE_TTS_MODEL=neural
GOOGLE_TTS_ENDPOINT=texttospeech.googleapis.com

SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-key

ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change-me-in-production

ENABLE_COST_TRACKING=true
COST_TRACKING_ENABLED=true
